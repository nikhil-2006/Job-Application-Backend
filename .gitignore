```gitignore
# Node modules
node_modules/

# Environment variables
.env
.env.local
.env.*.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
dist/
build/

# TypeScript
*.tsbuildinfo

# OS files
.DS_Store
Thumbs.db

# VS Code
.vscode/

# Runtime files
*.pid
*.seed
*.pid.lock

# Coverage
coverage/

# Temporary files
tmp/
temp/

# MongoDB local data (if any)
data/
```
